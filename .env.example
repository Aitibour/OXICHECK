# =============================================================================
# HotelCheckIn — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/hotelcheckin?schema=public"

# ---- Auth / JWT ----
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- App ----
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ---- SendGrid (Email) ----
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@hotelcheckin.ca"

# ---- Twilio (SMS) ----
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ---- PMS Integrations ----
CLOUDBEDS_API_KEY=""
CLOUDBEDS_CLIENT_ID=""
CLOUDBEDS_CLIENT_SECRET=""

MEWS_CLIENT_TOKEN=""
MEWS_ACCESS_TOKEN=""
MEWS_PLATFORM_ADDRESS=""

LIGHTSPEED_API_KEY=""
LIGHTSPEED_CLIENT_ID=""
LIGHTSPEED_CLIENT_SECRET=""

# ---- Redis (Caching / Queues) ----
REDIS_URL="redis://localhost:6379"

# ---- Logging ----
LOG_LEVEL="debug"

# ---- File Storage (S3-compatible) ----
S3_BUCKET=""
S3_REGION="ca-central-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
